{
  "sqltools.connections": [
    {
      "name": "seasonal_japan",
      "driver": "PostgreSQL",
      "server": "localhost",
      "port": 55433,
      "database": "seasonal_japan",
      "username": "seasonal",
      "password": "seasonal_pw",
      "previewLimit": 50,
      "pgOptions": {
        "ssl": false
      }
    }
  ],

  "python.interpreter.infoVisibility": "never",

  "python.testing.pytestEnabled": true,
  "python.testing.unittestEnabled": false,
  "python.testing.pytestArgs": [
    "tests"
  ],

  "files.exclude": {
    "**/.venv": true,
    "**/__pycache__": true,
    "**/.pytest_cache": true,
    "**/.mypy_cache": true,
    "**/.DS_Store": true
  },

  "search.exclude": {
    "**/.venv": true,
    "**/__pycache__": true
  },

  "files.watcherExclude": {
    "**/.venv/**": true,
    "**/__pycache__/**": true
  },

  "editor.formatOnSave": true,

  "python.analysis.extraPaths": [
    "./src"
  ]
}